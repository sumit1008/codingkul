# ─── Backend API URL ──────────────────────────────────────────────────────────
# Dev (solo):     http://localhost:5000/api
# Dev (LAN):      http://192.168.x.x:5000/api
# Production:     https://your-backend.railway.app/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ─── Razorpay (public key only — never expose KEY_SECRET here) ───────────────
# Only the Key ID is needed on the frontend; the secret stays in the backend
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
