# ─── MongoDB Atlas (same cluster as Backend) ─────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/codingkul?retryWrites=true&w=majority

# ─── Admin JWT ────────────────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=your-admin-jwt-secret-min-64-chars

# ─── Seed credentials (scripts/seed.ts only — not runtime) ──────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=strong-password-here

# ─── App URL ─────────────────────────────────────────────────────────────────
# Dev:  http://localhost:3001
# Prod: https://your-admin.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3001
