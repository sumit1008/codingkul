# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/algoshashtra

# JWT — generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Admin seed credentials (used only by scripts/seed.ts)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-strong-password

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
